# Public URL used in docs, redirects, and future integrations.
# On Vercel this should be the stable Production Domain, for example:
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_APP_URL=""

# Monthly report screenshot OCR is a local-only macOS helper.
# Keep this disabled in Vercel/production. Excel/CSV import and report export do not need it.
ENABLE_MACOS_OCR="false"

# Optional database settings for the broader application-management modules.
# The monthly report generator does not require a database for Excel parsing, preview, or export.
DATABASE_URL="postgresql://application:application@localhost:5432/application_progress?schema=public"
POSTGRES_DB="application_progress"
POSTGRES_USER="application"
POSTGRES_PASSWORD="application"
